{
  "name": "tinh-extension",
  "private": true,
  "version": "0.1.0",
  "description": "Tỉnh — browser extension giúp sinh viên tái chiếm tính chủ thể trước thuật toán mạng xã hội (RBL Level 5, Nhóm 07).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx && prettier --check \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "zip": "npm run build && node scripts/zip.mjs"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0",
    "@types/chrome": "0.0.287",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.15.0",
    "@typescript-eslint/parser": "8.15.0",
    "@vitejs/plugin-react": "4.3.4",
    "archiver": "7.0.1",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "jsdom": "25.0.1",
    "prettier": "3.4.2",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
}
